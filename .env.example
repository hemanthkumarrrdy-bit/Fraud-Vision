# ─────────────────────────────────────────────
# Fraud Vision — Environment Variables Example
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Database
# PostgreSQL connection string. Falls back to SQLite if unreachable.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fraud_vision

# JWT Secret Key — CHANGE THIS in production!
SECRET_KEY=goldman_sachs_secret_key_change_me_in_production_123456

# JWT token expiry in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── SMTP (for scheduled report emails) ───────
SMTP_SERVER=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SENDER_EMAIL=alerts@fraudvision.com
